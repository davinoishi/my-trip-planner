# ─── Database ────────────────────────────────────────────────────────────────
# For local dev (direct to Postgres): postgresql://tripit:tripit_dev_password@localhost:5432/tripit
# For production (via PgBouncer):     postgresql://tripit:YOURPASSWORD@pgbouncer:5432/tripit
DATABASE_URL=postgresql://tripit:tripit_dev_password@localhost:5432/tripit

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://:redis_dev_password@localhost:6379

# ─── MinIO (S3-compatible storage) ───────────────────────────────────────────
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin_dev_password
MINIO_PUBLIC_URL=http://localhost:9000  # Used for presigned URL generation

# ─── ClamAV ──────────────────────────────────────────────────────────────────
CLAMAV_HOST=localhost
CLAMAV_PORT=3310

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
BETTER_AUTH_SECRET=generate-a-random-32-char-string-here

# ─── Google OAuth (required) ─────────────────────────────────────────────────
# 1. Go to https://console.cloud.google.com
# 2. Create a project → APIs & Services → Credentials → OAuth 2.0 Client ID
# 3. Add authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── External APIs ────────────────────────────────────────────────────────────
MAPBOX_TOKEN=pk.your-mapbox-token
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# ─── Gmail IMAP (for email booking import) ───────────────────────────────────
# Create a dedicated Gmail account for forwarding booking confirmations
# Use an App Password (not your regular Gmail password):
#   Gmail Settings → Security → 2-Step Verification → App Passwords
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=your-trips-import@gmail.com
IMAP_PASSWORD=your-gmail-app-password
IMAP_POLL_INTERVAL_SECONDS=300

# ─── Docker Compose secrets (used in infra/docker-compose.yml) ───────────────
POSTGRES_PASSWORD=tripit_dev_password
REDIS_PASSWORD=redis_dev_password
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin_dev_password
APP_URL=http://localhost
